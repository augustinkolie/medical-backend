# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:votre_mot_de_passe@localhost:5432/medirdv"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Utilisez une chaîne aléatoire longue (min. 32 caractères) en production
JWT_SECRET="votre_secret_jwt_tres_long_et_aleatoire_changez_en_prod"
JWT_EXPIRES_IN="24h"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL du frontend Angular (séparées par des virgules pour plusieurs origines)
ALLOWED_ORIGIN="http://localhost:4200"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Nombre de requêtes max par fenêtre de temps
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
